{
  "name": "Chrome Butler",
  "description": "Raycast features directly on the browser",
  "version": "1.0.0",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png",
    "192": "images/icon-192.png",
    "512": "images/icon-512.png"
  },
  "manifest_version": 3,
  "action": {
    "default_popup": "main.html"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "js": ["scripts/main.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
